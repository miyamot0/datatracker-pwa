{
  "references": [{ "path": "./tsconfig.app.json" }, { "path": "./tsconfig.node.json" }],
  "compilerOptions": {
    "typeRoots": ["./node_modules/@types", "./node_modules"],
    "types": ["vite-plugin-pwa/client", "vitest/globals", "@types/wicg-file-system-access", "node"],
    "lib": ["ES2021.String", "DOM", "DOM.Iterable", "DOM.AsyncIterable"],
    "strict": true,
    "noImplicitAny": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["./src/**/*.{ts,tsx}"],
  "exclude": ["node_modules", "./src/**/*.test.{ts,tsx}", "**/*.test.{ts,tsx}"]
}
