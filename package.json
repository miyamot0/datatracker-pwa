{
  "name": "data-tracker",
  "type": "module",
  "description": "DataTracker is a web application that helps you to track various forms of behavioral phenomena",
  "homepage": "https://www.smallnstats.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/miyamot0/datatracker-pwa"
  },
  "author": {
    "name": "Shawn P. Gilroy",
    "url": "https://www.smallnstats.com",
    "email": "sgilroy1@lsu.edu"
  },
  "maintainers": [
    {
      "name": "Shawn P. Gilroy",
      "url": "https://www.smallnstats.com",
      "email": "sgilroy1@lsu.edu"
    }
  ],
  "private": true,
  "bugs": {
    "url": "https://github.com/miyamot0/datatracker-pwa/issues"
  },
  "keywords": [
    "behavioral data",
    "data collection",
    "single case design",
    "research software"
  ],
  "license": "Apache-2.0",
  "version": "0.5.7",
  "scripts": {
    "dev-island": "vite --mode island",
    "dev": "vite",
    "build-island": "tsgo -b && vite build --mode island",
    "build": "tsgo && vite build",
    "build:peek": "tsgo --showConfig --listFiles",
    "build:quick": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "check-licenses": "npx license-report --only=prod --output=json > ./src/assets/licenses.json",
    "build-readme": "tsx ./scripts/index.ts",
    "prebuild": "yarn run lint && yarn run test && yarn run check-licenses && yarn run build-readme",
    "test": "vitest run --coverage",
    "test-old": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "knip": "knip"
  },
